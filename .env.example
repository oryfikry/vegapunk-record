# Vegapunk-Record local-first defaults. Copy to .env for local overrides.
HOST=127.0.0.1
# Required only when HOST=0.0.0.0. Keep Stella behind a firewall or reverse proxy.
STELLA_ALLOW_PUBLIC_BIND=0
# Optional auth token for protected write/setup endpoints. Send as Authorization: Bearer <token> or X-Stella-Auth-Token.
STELLA_AUTH_TOKEN=
PORT=3003
SQLITE_PATH=./data/punk-records.sqlite
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
LLM_PROVIDER=mock

# Provider keys are intentionally blank placeholders. Tests and CI must not need them.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=
