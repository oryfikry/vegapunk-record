PORT=3003
SQLITE_PATH=./data/punk-records.sqlite
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
LLM_PROVIDER=mock

# Provider keys are intentionally blank placeholders. Tests and CI must not need them.
